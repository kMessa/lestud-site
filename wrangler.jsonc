{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lestud-site",
  "compatibility_date": "2026-05-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [".git/**", ".wrangler/**", "node_modules/**"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
